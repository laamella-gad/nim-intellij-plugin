<idea-plugin>
    <id>com.laamella.nim</id>
    <name>Nim</name>
    <vendor>Laamella Gad</vendor>
    <description><![CDATA[
        Nim language support via <a href="https://github.com/nim-lang/langserver">nimlangserver</a>.<br/>
        Provides completion, hover, go-to-definition, find usages, diagnostics, inlay hints, and more.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Nim"
                  language="Nim"
                  implementationClass="com.laamella.nim.NimFileType"
                  extensions="nim;nims;nimble;nimscript"
                  fieldName="INSTANCE"/>

        <applicationService serviceImplementation="com.laamella.nim.settings.NimSettings"/>

        <nonProjectFileWritingAccessExtension implementation="com.laamella.nim.NimWritingAccessExtension"/>
        <directoryProjectConfigurator implementation="com.laamella.nim.NimProjectConfigurator"/>

        <applicationConfigurable parentId="language"
                                 instance="com.laamella.nim.settings.NimSettingsConfigurable"
                                 id="com.laamella.nim.settings.NimSettingsConfigurable"
                                 displayName="Nim"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="nim"
                name="Nim Language Server"
                factoryClass="com.laamella.nim.lsp.NimLanguageServerFactory">
            <description><![CDATA[
                nimlangserver — official Nim LSP wrapping nimsuggest.
                Install: <code>nimble install nimlangserver</code>
            ]]></description>
        </server>

        <languageMapping language="Nim"
                         serverId="nim"
                         languageId="nim"/>

        <fileTypeMapping fileType="Nim"
                         serverId="nim"/>
    </extensions>
</idea-plugin>
