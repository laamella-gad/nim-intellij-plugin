<idea-plugin>
    <id>com.laamella.nim</id>
    <name>Nim using nimlangserver</name>
    <vendor email="hexagonaal@gmail.com" url="https://codeberg.org/laamella/nim-intellij-plugin">Laamella Gad</vendor>
    <description><![CDATA[
        Full Nim language support powered by the official <a href="https://github.com/nim-lang/langserver">nimlangserver</a>
        via <a href="https://github.com/redhat-developer/lsp4ij">LSP4IJ</a>.

        <ul>
            <li>Code completion, parameter info, and hover documentation</li>
            <li>Go to definition, find usages, and rename refactoring</li>
            <li>Inline diagnostics and inlay hints</li>
            <li>Code formatting via <code>nimpretty</code> (Reformat Code / Ctrl+Alt+L)</li>
            <li>Smart Enter indentation with 2-space default</li>
            <li>Syntax highlighting with bracket matching and auto-close</li>
            <li>Run and test configurations for <code>.nim</code> files</li>
            <li>New project wizard for Nim projects</li>
        </ul>

        <em>This is a community plugin, not officially supported by JetBrains or the Nim project.</em>

        <b>Getting Started</b>
        <ol>
            <li>Install Nim and Nimble: <a href="https://nim-lang.org/install.html">nim-lang.org/install.html</a></li>
            <li>Install nimlangserver: <code>nimble install nimlangserver</code></li>
            <li>(Optional) Install nimpretty for formatting: <code>nimble install nimpretty</code></li>
            <li>Open <b>Settings → Languages &amp; Frameworks → Nim</b> and verify the server path.</li>
            <li>Open any <code>.nim</code>, <code>.nims</code>, or <code>.nimble</code> file — LSP features activate automatically.</li>
        </ol>
    ]]></description>
    <change-notes><![CDATA[
        <b>0.2.0</b>
        <ul>
            <li><code>tests/</code> directory automatically marked as test source root</li>
        </ul>
        <b>0.1.0 (initial release)</b>
        <ul>
            <li>Nim language support via nimlangserver and LSP4IJ</li>
            <li>Syntax highlighting, bracket matching, and auto-close quotes</li>
            <li>Smart Enter indentation</li>
            <li>Code formatting via nimpretty (Reformat Code / Ctrl+Alt+L)</li>
            <li>Run and test configurations</li>
            <li>New project wizard</li>
            <li>Source root detection from <code>.nimble</code> files</li>
            <li>Project structure re-configured automatically when <code>.nimble</code> file changes</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Nim"
                  language="Nim"
                  implementationClass="com.laamella.nim.NimFileType"
                  extensions="nim;nims;nimble;nimscript"
                  fieldName="INSTANCE"/>

        <applicationService serviceImplementation="com.laamella.nim.settings.NimSettings"/>

        <lang.parserDefinition language="Nim" implementationClass="com.laamella.nim.NimParserDefinition"/>
        <lang.syntaxHighlighterFactory language="Nim" implementationClass="com.laamella.nim.NimSyntaxHighlighterFactory"/>
        <lang.commenter language="Nim" implementationClass="com.laamella.nim.NimCommenter"/>
        <lang.quoteHandler language="Nim" implementationClass="com.laamella.nim.NimQuoteHandler"/>
        <lang.braceMatcher language="Nim" implementationClass="com.laamella.nim.NimBraceMatcher"/>
        <lang.foldingBuilder language="Nim" implementationClass="com.redhat.devtools.lsp4ij.features.foldingRange.LSPFoldingRangeBuilder" order="first"/>
        <lang.psiStructureViewFactory language="Nim" implementationClass="com.redhat.devtools.lsp4ij.features.documentSymbol.LSPDocumentSymbolStructureViewFactory"/>
        <codeInsight.parameterInfo language="Nim" implementationClass="com.redhat.devtools.lsp4ij.features.signatureHelp.LSPParameterInfoHandler"/>

        <configurationType implementation="com.laamella.nim.run.NimRunConfigurationType"/>
        <runConfigurationProducer implementation="com.laamella.nim.run.NimRunConfigurationProducer"/>
        <configurationType implementation="com.laamella.nim.run.NimTestRunConfigurationType"/>
        <runConfigurationProducer implementation="com.laamella.nim.run.NimTestRunConfigurationProducer"/>

        <postStartupActivity implementation="com.laamella.nim.NimProjectConfigurator"/>

        <externalFormatProcessor implementation="com.laamella.nim.NimFormatProcessor"/>

        <langCodeStyleSettingsProvider implementation="com.laamella.nim.NimLanguageCodeStyleSettingsProvider"/>

        <lineIndentProvider implementation="com.laamella.nim.NimLineIndentProvider"/>

        <newProjectWizard.languageGenerator implementation="com.laamella.nim.newproject.NimNewProjectWizard"/>

        <notificationGroup id="Nim" displayType="BALLOON" isLogByDefault="true"/>

        <applicationConfigurable parentId="language"
                                 instance="com.laamella.nim.settings.NimSettingsConfigurable"
                                 id="com.laamella.nim.settings.NimSettingsConfigurable"
                                 displayName="Nim"/>
    </extensions>

    <projectListeners>
        <listener class="com.laamella.nim.NimNimbleFileListener"
                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
    </projectListeners>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="nim"
                name="Nim Language Server"
                factoryClass="com.laamella.nim.lsp.NimLanguageServerFactory">
            <description><![CDATA[
                nimlangserver — official Nim LSP wrapping nimsuggest.
                Install: <code>nimble install nimlangserver</code>
            ]]></description>
        </server>

        <languageMapping language="Nim"
                         serverId="nim"
                         languageId="nim"/>

        <fileTypeMapping fileType="Nim"
                         serverId="nim"/>
    </extensions>
</idea-plugin>
